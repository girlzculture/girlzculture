NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAIL_DOMAIN=girlzculture.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ALLOW_INDEXING=false

# Stripe test mode only. Never expose STRIPE_SECRET_KEY or the webhook secret.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_BASIC_PRICE_ID=price_
STRIPE_GROWTH_PRICE_ID=price_
STRIPE_PREMIUM_PRICE_ID=price_
INTERNAL_API_SECRET=replace-with-a-long-random-server-only-value
PASSWORD_RESET_SECRET=replace-with-another-long-random-server-only-value
MFA_CODE_SECRET=replace-with-at-least-32-random-server-only-characters
ADMIN_MFA_MODE=every_login
MFA_CHALLENGE_TTL_MINUTES=10
MFA_MAX_ATTEMPTS=5
MFA_RESEND_COOLDOWN_SECONDS=60

# Web Push. Generate once with: node scripts/generate-vapid.mjs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@girlzculture.com
COMPLAINT_RATE_LIMIT_SALT=replace-with-a-long-random-server-only-value

# Transactional email: https://resend.com
RESEND_API_KEY=
EMAIL_FROM_SECURITY=Girlz Culture Security <noreply@notifications.girlzculture.com>
EMAIL_FROM_BOOKINGS=Girlz Culture Bookings <bookings@notifications.girlzculture.com>
EMAIL_FROM_ACCOUNT=Girlz Culture <hello@notifications.girlzculture.com>
EMAIL_FROM_SUPPORT=Girlz Culture Support <support@notifications.girlzculture.com>

# Booking text messages: https://www.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Official social channels. Unconfigured links stay hidden from /social.
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_FACEBOOK_URL=

# Google Cloud browser key: enable Maps JavaScript API and Places API (New).
# Restrict by production/preview website referrers and restrict to those APIs.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Google Cloud server key: enable Geocoding API only. Keep server-side and
# restrict to Geocoding API plus the deployment's stable outbound IP where available.
GOOGLE_MAPS_SERVER_API_KEY=
