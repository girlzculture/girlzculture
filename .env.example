NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_ADMIN_EMAIL=
ADMIN_EMAIL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ALLOW_INDEXING=false

# Stripe test mode only. Never expose STRIPE_SECRET_KEY or the webhook secret.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_BASIC_PRICE_ID=price_
STRIPE_GROWTH_PRICE_ID=price_
STRIPE_PREMIUM_PRICE_ID=price_
INTERNAL_API_SECRET=replace-with-a-long-random-server-only-value
PASSWORD_RESET_SECRET=replace-with-another-long-random-server-only-value
MFA_CODE_SECRET=replace-with-at-least-32-random-server-only-characters

# Web Push. Generate once with: node scripts/generate-vapid.mjs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@girlzculture.com

# Transactional email: https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Girlz Culture <bookings@notifications.girlzculture.com>

# Booking text messages: https://www.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
